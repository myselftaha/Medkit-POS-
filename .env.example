MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
VITE_API_URL=http://localhost:5000

# Comma-separated allowlist for CORS (no wildcards in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=app-password
STORE_EMAIL=you@example.com
STORE_NAME=AI Pharmacy
OWNER_EMAIL=owner@example.com

# Unsafe debug endpoints (MUST stay false in production)
ALLOW_SEED_ENDPOINT=false
ALLOW_TEST_ENDPOINTS=false
ALLOW_HARD_RESET_ENDPOINT=false
